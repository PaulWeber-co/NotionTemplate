{
  "manifest_version": 3,
  "name": "Anti Procrastinator",
  "version": "1.0.0",
  "description": "Dein persönlicher Produktivitäts-Hub — To-Do, Kalender, Studienplan, Lofi Music.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Anti Procrastinator öffnen"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "geolocation"
  ],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://api.allorigins.win/*",
    "https://www.youtube.com/*"
  ]
}


